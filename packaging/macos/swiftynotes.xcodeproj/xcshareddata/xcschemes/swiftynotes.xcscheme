            BlueprintName = "swiftynotes"
            ReferencedContainer = "container:swiftynotes.xcodeproj">
         </BuildableReference>
      </BuildableProductRunnable>
      <!--
      Xcode launches the .app binary via debugserver, NOT through Launch
      Services, so the Info.plist's LSEnvironment is NOT applied under
      Cmd+R. Mirror it here so libadwaita finds its GSettings schemas at
      startup; otherwise the app aborts with "No GSettings schemas are
      installed on the system".
      -->
      <EnvironmentVariables>
         <EnvironmentVariable
            key = "XDG_DATA_DIRS"
            value = "/opt/homebrew/share"
            isEnabled = "YES">
         </EnvironmentVariable>
      </EnvironmentVariables>
   </LaunchAction>
