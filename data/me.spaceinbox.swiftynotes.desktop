[Desktop Entry]
Name=Swifty Notes
Comment=Native GTK markdown notes with preview and CLI automation
Exec=swiftynotes %F
Icon=me.spaceinbox.swiftynotes
Terminal=false
Type=Application
Categories=Utility;TextEditor;GTK;GNOME;
Keywords=notes;markdown;editor;text;cli;automation;
MimeType=text/markdown;
StartupNotify=true
Actions=new-window;

[Desktop Action new-window]
Name=New Window
Exec=swiftynotes
