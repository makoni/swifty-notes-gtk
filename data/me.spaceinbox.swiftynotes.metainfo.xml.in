<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>me.spaceinbox.swiftynotes</id>
  <metadata_license>FSFAP</metadata_license>
  <project_license>MIT</project_license>
  <name>Swifty Notes</name>
  <developer id="me.spaceinbox">
    <name>Sergey Armodin</name>
  </developer>
  <summary>Native GTK markdown notes with preview and automation</summary>
  <launchable type="desktop-id">me.spaceinbox.swiftynotes.desktop</launchable>
  <branding>
    <color type="primary" scheme_preference="light">#5b7cff</color>
    <color type="primary" scheme_preference="dark">#7f93ff</color>
  </branding>
  <categories>
    <category>Utility</category>
    <category>TextEditor</category>
  </categories>
  <keywords>
    <keyword>notes</keyword>
    <keyword>markdown</keyword>
    <keyword>editor</keyword>
    <keyword>preview</keyword>
    <keyword>cli</keyword>
    <keyword>automation</keyword>
  </keywords>
  <description>
    <p>Swifty Notes is a native GTK/libadwaita Markdown notes application for Linux written in Swift.</p>
    <p>The desktop app is the primary experience: write, organize, and preview Markdown notes with native GTK widgets, autosave, remembered workspace state, and adjustable editor settings such as font size, wrapping, indentation, and appearance.</p>
    <p>The included CLI works on the same file-backed notes so shell scripts, automation, and AI agents can safely inspect or update notes without a separate database or background service.</p>
    <ul>
      <li>Create, rename, duplicate, export, and delete Markdown notes.</li>
      <li>Autosave edits, remember workspace state, and keep note-local image assets together with each note.</li>
      <li>Adjust editor font size and other writing preferences to fit different screens and workflows.</li>
      <li>Choose where notes are stored, including a cloud-synced folder, so the same plain files can stay in sync across devices.</li>
      <li>Import images with drag and drop and render Markdown with a native GTK preview instead of a web view.</li>
      <li>Use the CLI for JSON-friendly note automation from scripts, shell pipelines, and AI agents.</li>
    </ul>
  </description>
  <provides>
    <binary>swiftynotes</binary>
    <mediatype>text/markdown</mediatype>
  </provides>
  <screenshots>
    <screenshot type="default">
      <caption>Main window with sidebar, editor, and native Markdown preview.</caption>
      <image type="source" width="2000" height="1240">@SCREENSHOT_MAIN_URL@</image>
    </screenshot>
    <screenshot>
      <caption>Markdown writing workflow with the formatting toolbar and live native preview.</caption>
      <image type="source" width="2000" height="1240">@SCREENSHOT_EDITOR_URL@</image>
    </screenshot>
    <screenshot>
      <caption>Desktop and CLI workflows share the same notes for automation-friendly editing.</caption>
      <image type="source" width="2000" height="1240">@SCREENSHOT_CLI_URL@</image>
    </screenshot>
  </screenshots>
  <content_rating type="oars-1.1"/>
  <url type="homepage">https://github.com/makoni/swifty-notes-gtk</url>
  <url type="bugtracker">https://github.com/makoni/swifty-notes-gtk/issues</url>
  <url type="vcs-browser">https://github.com/makoni/swifty-notes-gtk</url>
  <releases>
    <release version="@VERSION@" date="@DATE@">
      <description>
        <p>This update adds a document outline for quick navigation, full Find &amp; Replace, and live search highlighting in the preview.</p>
        <ul>
          <li>A new Outline panel (toggle with F9) lists every heading in the current note so you can jump around long documents at a glance. It tracks your position as you scroll, shows a breadcrumb of where you are, and lets you filter headings, collapse sections, fold them in the editor, and even drag to reorder whole sections. Press Ctrl+G for a command-palette-style quick jump to any heading.</li>
          <li>Find &amp; Replace arrives: Ctrl+F searches, Ctrl+H replaces, with Replace and Replace All, case-sensitive matching, match counts, and smooth scrolling to each result. Search works in both the editor and the live preview, and remembers your last query.</li>
          <li>Search matches now highlight directly in the rendered preview — including inside fenced code blocks and table cells — so you can see every hit in context, not just in the raw text.</li>
          <li>Editing large, heading-heavy notes feels noticeably smoother thanks to a leaner preview and outline that do far less redrawing while you write and scroll.</li>
        </ul>
      </description>
    </release>
    <release version="1.1.6" date="2026-05-14">
      <description>
        <p>This update makes Swifty Notes feel faster, calmer, and more polished while you write.</p>
        <ul>
          <li>Typing now feels smoother in long notes, with fewer distracting preview refreshes while you write.</li>
          <li>The live preview updates more gracefully, so editing feels steadier and less visually jumpy.</li>
          <li>Large text-heavy notes stay more responsive during everyday writing and scrolling.</li>
          <li>Under-the-hood polish keeps the app feeling more consistent across the editor, preview, and sidebar.</li>
        </ul>
      </description>
    </release>
    <release version="1.1.5" date="2026-04-30">
      <description>
        <p>This update brings note recovery, smarter paste, list-rendering polish, and richer out-of-the-box spell-check.</p>
        <ul>
          <li>New Trash: deleting a note moves it into a sidebar Trash section instead of erasing it for good. Restore from the right-click menu, the toast's Undo button, or empty the bin manually. A new "Empty Trash automatically" preference in Settings → Storage prunes trashed notes after Never / 7 / 30 / 90 / 365 days (default 30). Deleting a folder also routes nested notes through Trash, so they can still be restored individually.</li>
          <li>Pasting a bare http/https URL now inserts a Markdown link automatically: with no selection it becomes <code>[url](url)</code>; with text selected the selection becomes the link label. Pasting inside a code block keeps the URL raw.</li>
          <li>Pasting a copied image (Ctrl+V) or files copied from a file manager now imports them into the active note's <code>assets</code> folder and inserts a Markdown reference, just like drag-and-drop.</li>
          <li>Task-list checkboxes in the preview are clickable — toggling <code>[ ]</code> / <code>[x]</code> updates the editor and saves automatically.</li>
          <li>Markdown rendering polish: loose lists (items separated by blank lines) get paragraph-style spacing per item, ordered lists restart numbering after a blank line, standalone image lines render as full-width block images, and badge rows keep their requested size.</li>
          <li>The New Folder dialog now treats slashes as nesting separators and rejects hidden, whitespace-only, or Windows-incompatible names with a clear message.</li>
          <li>The Flatpak build bundles 21 hunspell dictionaries (en, de, es, fr, it, pl, ru, uk, cs, da, nl, fi, hu, nb, pt, ro, sk, sl, sr, sv, he) so inline spell-check works for those languages out of the box without installing extra packages.</li>
        </ul>
      </description>
    </release>
    <release version="1.1.4" date="2026-04-28">
      <description>
        <p>This update brings folders and inline spell-checking to Swifty Notes — two of the most-requested features for organising notes and writing comfortably.</p>
        <ul>
          <li>Notes can now live in folders. Create them from the new "+ folder" button in the toolbar or by right-clicking any folder in the sidebar (New subfolder, Rename, Delete with confirmation). Folders can be nested as deep as your file system allows.</li>
          <li>Drag-and-drop in the sidebar: drag a note onto another folder to move it, drag a folder onto another folder to re-parent it. Hover over a closed folder during a drag and it expands automatically so you can drop into deep targets.</li>
          <li>"Move to…" entry in a note's right-click menu offers a quick folder picker if drag-and-drop isn't your thing.</li>
          <li>Inline spell-checking: misspellings get a red wavy underline in the editor. Right-click a misspelled word for suggestions, Add to Dictionary, or Ignore. The language follows your system locale by default and can be overridden in Settings.</li>
          <li>The CLI gained full folder support so scripts and AI agents can do everything the GUI does: <code>swiftynotes cli list --folder Work</code>, <code>swiftynotes cli folders create / rm / rename / move</code>, <code>swiftynotes cli move &lt;note-id&gt; --folder Personal</code>. Recursive deletes refuse to run without <code>--yes</code>, apt-style.</li>
          <li>Folders are stored as plain directories alongside your notes — no database, so syncing through Syncthing, Nextcloud, Dropbox or Git keeps working exactly as before.</li>
        </ul>
      </description>
    </release>
    <release version="1.1.3" date="2026-04-26">
      <description>
        <p>This update fixes a few cross-platform packaging issues and the way Swifty Notes handles your notes folder.</p>
        <ul>
          <li>The Snap build now starts cleanly under strict confinement on Ubuntu 26.04 and other recent setups. Previous versions could abort on launch with a D-Bus AppArmor policy error.</li>
          <li>The Flatpak build can now point its notes folder at any directory under your home, including cloud-synced ones like ~/Sync/Notes or ~/Dropbox/Notes. Note that approving the new permission may require accepting an update in your software centre.</li>
          <li>Switching the notes folder is now safer: if anything goes wrong mid-move, your notes are restored to the original location instead of being left half-moved.</li>
          <li>Errors from the "Could not change the notes folder" dialog now show a friendly explanation instead of "(NSCocoaErrorDomain error 512)".</li>
          <li>The Insert Table button icon now renders in standalone document windows, not just the main library window.</li>
        </ul>
      </description>
    </release>
    <release version="1.1.2" date="2026-04-24">
      <description>
        <p>This update focuses on making the Markdown editor and preview more productive day to day.</p>
        <ul>
          <li>Fenced code blocks in the preview now show a quick Copy button, so you can grab a snippet in one click instead of selecting it by hand.</li>
          <li>Code blocks are now syntax-highlighted in the preview for popular languages, making longer snippets much easier to scan.</li>
          <li>A new Insert Table button in the formatting toolbar lets you pick a size from a visual grid and set per-column alignment, then drops a ready-to-edit Markdown table into the note.</li>
          <li>The formatting toolbar now collapses to its compact layout based on its own content width, so buttons no longer disappear behind the header menu on narrower editor widths.</li>
          <li>The Table button and other bundled formatting icons now render correctly on systems where the active icon theme doesn't ship a matching symbolic.</li>
        </ul>
      </description>
    </release>
    <release version="1.1.1" date="2026-04-22">
      <description>
        <p>This update brings back a few things that quietly stopped working on some setups in 1.1.0, and polishes exporting and window handling.</p>
        <ul>
          <li>Import, Open Markdown File, Export, Save As, and Choose Notes Folder dialogs now open reliably. On some systems they were silently doing nothing after upgrading to 1.1.0.</li>
          <li>Images attached to notes show up in the preview again — previously they could quietly fail to load after launching the app.</li>
          <li>Notes and folders whose paths contain spaces — for example a cloud-synced folder called "Cloud Disk" or "My Notes" — can now be imported, opened, and exported without "file not found" errors.</li>
          <li>Exporting a note with images now writes an "assets" folder next to the Markdown file, so the exported bundle stays self-contained when you move it into a blog repository or a backup.</li>
          <li>Right-clicking the Swifty Notes icon in your dock or app grid now offers a "New Window" action, so you can open the notes library even when you're already editing an external Markdown document.</li>
        </ul>
      </description>
    </release>
    <release version="1.1.0" date="2026-04-21">
      <description>
        <p>This update makes the Markdown preview feel richer for notes that mix in online images, badges, and animations.</p>
        <ul>
          <li>Images loaded from the web — including animated GIFs and WebP animations — now render directly in the preview instead of showing a placeholder.</li>
          <li>Rows of inline badges, like CI status or shields.io images, now flow on a single line and remain clickable.</li>
          <li>HTML <code>&lt;img&gt;</code> tags written directly inside Markdown now render as proper preview images.</li>
        </ul>
      </description>
    </release>
    <release version="1.0.2" date="2026-04-15">
      <description>
        <p>This update makes split view more comfortable on tighter window sizes and adds a more direct way to open and edit Markdown files outside your library.</p>
        <ul>
          <li>You can now open and edit standalone Markdown files without importing them first, including from your file manager’s Open With flow.</li>
          <li>The formatting toolbar now adapts more gracefully as the editor narrows, so actions stay easier to reach instead of disappearing off the edge.</li>
          <li>Very narrow layouts can now flow the formatting toolbar into two rows, keeping the preview usable without hiding the sidebar.</li>
          <li>Split view now shares space more gracefully between the editor and preview on smaller screens.</li>
        </ul>
      </description>
    </release>
    <release version="1.0.1" date="2026-04-13">
      <description>
        <p>This update makes command-line workflows friendlier for packaged installs and keeps release builds more consistent across Linux formats.</p>
        <ul>
          <li>The CLI now better fits Flathub installs, with clearer guidance for terminal use and improved note discovery when your notes live in Flatpak storage.</li>
          <li>Release packaging and version reporting are now aligned more consistently across Flatpak, Debian, and RPM builds.</li>
          <li>Project and store presentation were refreshed with updated screenshots, links, and release metadata.</li>
        </ul>
      </description>
    </release>
    <release version="1.0.0" date="2026-04-10">
      <description>
        <p>Native GTK release with Markdown preview, editor customization, configurable note storage for cloud-synced folders, note-local image assets, and CLI automation for scripts and AI agents.</p>
      </description>
    </release>
  </releases>
</component>
