<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>me.spaceinbox.swiftynotes</id>
  <metadata_license>FSFAP</metadata_license>
  <project_license>MIT</project_license>
  <name>Swifty Notes</name>
  <developer id="me.spaceinbox">
    <name>Sergey Armodin</name>
  </developer>
  <summary>Native GTK markdown notes with preview and automation</summary>
  <launchable type="desktop-id">me.spaceinbox.swiftynotes.desktop</launchable>
  <branding>
    <color type="primary" scheme_preference="light">#5b7cff</color>
    <color type="primary" scheme_preference="dark">#7f93ff</color>
  </branding>
  <categories>
    <category>Utility</category>
    <category>TextEditor</category>
  </categories>
  <keywords>
    <keyword>notes</keyword>
    <keyword>markdown</keyword>
    <keyword>editor</keyword>
    <keyword>preview</keyword>
    <keyword>cli</keyword>
    <keyword>automation</keyword>
  </keywords>
  <description>
    <p>Swifty Notes is a native GTK/libadwaita Markdown notes application for Linux written in Swift.</p>
    <p>The desktop app is the primary experience: write, organize, and preview Markdown notes with native GTK widgets, autosave, remembered workspace state, and adjustable editor settings such as font size, wrapping, indentation, and appearance.</p>
    <p>The included CLI works on the same file-backed notes so shell scripts, automation, and AI agents can safely inspect or update notes without a separate database or background service.</p>
    <ul>
      <li>Create, rename, duplicate, export, and delete Markdown notes.</li>
      <li>Autosave edits, remember workspace state, and keep note-local image assets together with each note.</li>
      <li>Adjust editor font size and other writing preferences to fit different screens and workflows.</li>
      <li>Choose where notes are stored, including a cloud-synced folder, so the same plain files can stay in sync across devices.</li>
      <li>Import images with drag and drop and render Markdown with a native GTK preview instead of a web view.</li>
      <li>Use the CLI for JSON-friendly note automation from scripts, shell pipelines, and AI agents.</li>
    </ul>
  </description>
  <provides>
    <binary>swiftynotes</binary>
    <mediatype>text/markdown</mediatype>
  </provides>
  <screenshots>
    <screenshot type="default">
      <caption>Main window with sidebar, editor, and native Markdown preview.</caption>
      <image type="source" width="3416" height="2104">@SCREENSHOT_MAIN_URL@</image>
    </screenshot>
    <screenshot>
      <caption>Markdown writing workflow with the formatting toolbar and live native preview.</caption>
      <image type="source" width="3416" height="2104">@SCREENSHOT_EDITOR_URL@</image>
    </screenshot>
    <screenshot>
      <caption>Desktop and CLI workflows share the same notes for automation-friendly editing.</caption>
      <image type="source" width="3416" height="2104">@SCREENSHOT_CLI_URL@</image>
    </screenshot>
  </screenshots>
  <content_rating type="oars-1.1"/>
  <url type="homepage">https://github.com/makoni/swifty-notes-gtk</url>
  <url type="bugtracker">https://github.com/makoni/swifty-notes-gtk/issues</url>
  <url type="vcs-browser">https://github.com/makoni/swifty-notes-gtk</url>
  <releases>
    <release version="@VERSION@" date="@DATE@">
      <description>
        <p>This update makes split view much more comfortable on tighter window sizes, especially when you want to keep the preview open while editing.</p>
        <ul>
          <li>The formatting toolbar now adapts more gracefully as the editor narrows, so actions stay easier to reach instead of disappearing off the edge.</li>
          <li>Very narrow layouts can now flow the formatting toolbar into two rows, keeping the preview usable without hiding the sidebar.</li>
          <li>Split view now shares space more gracefully between the editor and preview on smaller screens.</li>
        </ul>
      </description>
    </release>
    <release version="1.0.1" date="2026-04-13">
      <description>
        <p>This update makes command-line workflows friendlier for packaged installs and keeps release builds more consistent across Linux formats.</p>
        <ul>
          <li>The CLI now better fits Flathub installs, with clearer guidance for terminal use and improved note discovery when your notes live in Flatpak storage.</li>
          <li>Release packaging and version reporting are now aligned more consistently across Flatpak, Debian, and RPM builds.</li>
          <li>Project and store presentation were refreshed with updated screenshots, links, and release metadata.</li>
        </ul>
      </description>
    </release>
    <release version="1.0.0" date="2026-04-10">
      <description>
        <p>Native GTK release with Markdown preview, editor customization, configurable note storage for cloud-synced folders, note-local image assets, and CLI automation for scripts and AI agents.</p>
      </description>
    </release>
  </releases>
</component>
