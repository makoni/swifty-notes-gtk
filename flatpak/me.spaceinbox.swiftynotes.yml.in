app-id: me.spaceinbox.swiftynotes
runtime: org.gnome.Platform
runtime-version: "50"
sdk: org.gnome.Sdk
sdk-extensions:
  - org.freedesktop.Sdk.Extension.swift6
command: swiftynotes

finish-args:
  - --share=ipc
  - --socket=wayland
  - --socket=fallback-x11
  - --device=dri

build-options:
  append-path: /usr/lib/sdk/swift6/bin
  prepend-ld-library-path: /usr/lib/sdk/swift6/lib

modules:
  - name: swifty-notes
    buildsystem: simple
    sources:
      - type: dir
        path: @SOURCE_PATH@
      - type: git
        url: https://github.com/makoni/swift-adwaita.git
        commit: ba9baae3984aa2ec026ea946409737f9e8b73b98
        dest: flatpak-deps/swift-adwaita
      - type: git
        url: https://github.com/swiftlang/swift-markdown.git
        commit: 55d66d9a9e8d4fd3f48d111b0d437e82fe451903
        dest: flatpak-deps/swift-markdown
      - type: git
        url: https://github.com/swiftlang/swift-cmark.git
        commit: 924936d0427cb25a61169739a7660230bffa6ea6
        dest: flatpak-deps/swift-cmark
    build-commands:
      - rm -f Package.resolved && SWIFTY_NOTES_USE_BUNDLED_SWIFTPM_DEPS=1 packaging/release/assemble-install-root.sh --license-subdir me.spaceinbox.swiftynotes --repo-slug @REPO_SLUG@ --repo-ref @REPO_REF@ --dest flatpak-app --prefix /app
      - cp -a flatpak-app/app/. /app/
      - install -Dm644 flatpak-deps/swift-adwaita/LICENSE.txt /app/share/licenses/me.spaceinbox.swiftynotes/swift-adwaita/LICENSE.txt
      - install -Dm644 flatpak-deps/swift-markdown/LICENSE.txt /app/share/licenses/me.spaceinbox.swiftynotes/swift-markdown/LICENSE.txt
      - install -Dm644 flatpak-deps/swift-markdown/NOTICE.txt /app/share/licenses/me.spaceinbox.swiftynotes/swift-markdown/NOTICE.txt
      - install -Dm644 flatpak-deps/swift-cmark/COPYING /app/share/licenses/me.spaceinbox.swiftynotes/swift-cmark/COPYING
