app-id: me.spaceinbox.swiftynotes
runtime: org.gnome.Platform
runtime-version: "50"
sdk: org.gnome.Sdk
sdk-extensions:
  - org.freedesktop.Sdk.Extension.swift6
command: swiftynotes

finish-args:
  - --share=ipc
  - --socket=wayland
  - --socket=fallback-x11
  - --device=dri

build-options:
  append-path: /usr/lib/sdk/swift6/bin
  prepend-ld-library-path: /usr/lib/sdk/swift6/lib

modules:
  # GNOME Platform 50 doesn't ship libspelling-1 dev headers in the SDK, so
  # build it from source before our app module compiles the CSpelling shim.
  # Pinned to the latest stable tag at the time of writing.
  - name: libspelling
    buildsystem: meson
    config-opts:
      - -Dvapi=false
      - -Ddocs=false
    cleanup:
      - /lib/girepository-1.0
      - /share/gir-1.0
      - /share/vala
    sources:
      - type: git
        url: https://gitlab.gnome.org/GNOME/libspelling.git
        tag: "0.4.10"

  # Bundle hunspell dictionaries for the most common languages so spellcheck
  # works out-of-the-box on every Flatpak install. Without this the runtime's
  # /usr/share/hunspell/<lang>.dic symlinks point into org.gnome.Platform.Locale
  # extension subsets that Flatpak only fetches based on the user's
  # `flatpak config languages` setting — anyone whose system LANG isn't in
  # that set sees broken symlinks and a near-empty language picker.
  # Sourcing from LibreOffice/dictionaries (single repo, stable branch).
  - name: hunspell-dictionaries
    buildsystem: simple
    sources:
      - type: archive
        url: https://github.com/LibreOffice/dictionaries/archive/c011d96c90cc9c6c8b6d95ec6d83d11daacce994.tar.gz
        sha256: cdbc8d6d79425b2749f7eee077c107ef96fb23c44e4f0ca450897f0a4402581a
    build-commands:
      - mkdir -p /app/share/hunspell
      # English (US, GB)
      - install -m644 en/en_US.aff en/en_US.dic /app/share/hunspell/
      - install -m644 en/en_GB.aff en/en_GB.dic /app/share/hunspell/
      # German (de_DE) — upstream filename is de_DE_frami, rename to standard
      - install -m644 de/de_DE_frami.aff /app/share/hunspell/de_DE.aff
      - install -m644 de/de_DE_frami.dic /app/share/hunspell/de_DE.dic
      # French (fr_FR) — upstream stem is just "fr", rename
      - install -m644 fr_FR/fr.aff /app/share/hunspell/fr_FR.aff
      - install -m644 fr_FR/fr.dic /app/share/hunspell/fr_FR.dic
      # Spanish (es_ES) — every LATAM variant resolves to es_ES rules
      - install -m644 es/es_ES.aff es/es_ES.dic /app/share/hunspell/
      # Italian
      - install -m644 it_IT/it_IT.aff it_IT/it_IT.dic /app/share/hunspell/
      # Portuguese — Brazilian and European, separate orthographies
      - install -m644 pt_BR/pt_BR.aff pt_BR/pt_BR.dic /app/share/hunspell/
      - install -m644 pt_PT/pt_PT.aff pt_PT/pt_PT.dic /app/share/hunspell/
      # Russian
      - install -m644 ru_RU/ru_RU.aff ru_RU/ru_RU.dic /app/share/hunspell/
      # Dutch
      - install -m644 nl_NL/nl_NL.aff nl_NL/nl_NL.dic /app/share/hunspell/
      # Polish
      - install -m644 pl_PL/pl_PL.aff pl_PL/pl_PL.dic /app/share/hunspell/
      # Swedish
      - install -m644 sv_SE/sv_SE.aff sv_SE/sv_SE.dic /app/share/hunspell/
      # Czech
      - install -m644 cs_CZ/cs_CZ.aff cs_CZ/cs_CZ.dic /app/share/hunspell/
      # Hungarian
      - install -m644 hu_HU/hu_HU.aff hu_HU/hu_HU.dic /app/share/hunspell/
      # Greek
      - install -m644 el_GR/el_GR.aff el_GR/el_GR.dic /app/share/hunspell/
      # Romanian — upstream dir is "ro" but file stem is ro_RO already
      - install -m644 ro/ro_RO.aff ro/ro_RO.dic /app/share/hunspell/
      # Arabic
      - install -m644 ar/ar.aff ar/ar.dic /app/share/hunspell/
      # Danish
      - install -m644 da_DK/da_DK.aff da_DK/da_DK.dic /app/share/hunspell/
      # Norwegian Bokmål — lives under no/ alongside Nynorsk
      - install -m644 no/nb_NO.aff no/nb_NO.dic /app/share/hunspell/
      # Bulgarian
      - install -m644 bg_BG/bg_BG.aff bg_BG/bg_BG.dic /app/share/hunspell/
      # Bundle each language's upstream COPYING/README/license file under the
      # app's licenses dir so Flathub's redistribution rules are met. Some
      # dirs use README*, some Copyright*, so glob and skip dirs without one.
      - mkdir -p /app/share/licenses/me.spaceinbox.swiftynotes/hunspell-dictionaries
      - |
        for src in en de fr_FR es it_IT pt_BR pt_PT ru_RU nl_NL pl_PL sv_SE \
                   cs_CZ hu_HU el_GR ro ar da_DK no bg_BG; do
          dest="/app/share/licenses/me.spaceinbox.swiftynotes/hunspell-dictionaries/${src}"
          mkdir -p "${dest}"
          for f in "${src}"/Copyright* "${src}"/COPYING* "${src}"/README* "${src}"/LICENSE* "${src}"/license*; do
            if [ -f "${f}" ]; then install -m644 "${f}" "${dest}/$(basename "${f}")"; fi
          done
        done

  - name: swifty-notes
    buildsystem: simple
    sources:
      - type: dir
        path: @SOURCE_PATH@
      - type: git
        url: https://github.com/makoni/swift-adwaita.git
        commit: fccac15277fdf38aaf68d2e088caeb01f64f8945
        dest: flatpak-deps/swift-adwaita
      - type: git
        url: https://github.com/swiftlang/swift-markdown.git
        commit: 55d66d9a9e8d4fd3f48d111b0d437e82fe451903
        dest: flatpak-deps/swift-markdown
      - type: git
        url: https://github.com/swiftlang/swift-cmark.git
        commit: 924936d0427cb25a61169739a7660230bffa6ea6
        dest: flatpak-deps/swift-cmark
    build-commands:
      - rm -f Package.resolved && SWIFTY_NOTES_USE_BUNDLED_SWIFTPM_DEPS=1 packaging/release/assemble-install-root.sh --license-subdir me.spaceinbox.swiftynotes --repo-slug @REPO_SLUG@ --repo-ref @REPO_REF@ --dest flatpak-app --prefix /app
      - cp -a flatpak-app/app/. /app/
      - install -Dm644 flatpak-deps/swift-adwaita/LICENSE.txt /app/share/licenses/me.spaceinbox.swiftynotes/swift-adwaita/LICENSE.txt
      - install -Dm644 flatpak-deps/swift-markdown/LICENSE.txt /app/share/licenses/me.spaceinbox.swiftynotes/swift-markdown/LICENSE.txt
      - install -Dm644 flatpak-deps/swift-markdown/NOTICE.txt /app/share/licenses/me.spaceinbox.swiftynotes/swift-markdown/NOTICE.txt
      - install -Dm644 flatpak-deps/swift-cmark/COPYING /app/share/licenses/me.spaceinbox.swiftynotes/swift-cmark/COPYING
